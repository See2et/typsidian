{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2022",
    "allowJs": false,
    "noImplicitAny": true,
    "moduleResolution": "Bundler",
    "importHelpers": true,
    "strictNullChecks": true,
    "lib": [
      "DOM",
      "ES2022"
    ],
    "types": [
      "node",
      "obsidian"
    ]
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.mjs"
  ]
}
