{
  "name": "typsidian",
  "version": "0.0.1",
  "private": true,
  "description": "Typst live preview plugin for Obsidian",
  "scripts": {
    "build": "npm run typecheck && node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup:vault": "node scripts/setup-debug-vault.mjs",
    "setup:hot-reload": "node scripts/install-hot-reload.mjs",
    "dev:vault": "npm run setup:vault && npm run dev"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.8.7",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
